// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// =========== USER & STORE ============

enum UserRole {
  SUPER_ADMIN
  STORE_ADMIN
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum StoreStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

enum AddressLabel {
  HOME
  OFFICE
}

model User {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  email               String     @unique
  username            String     @unique
  password            String
  roles               UserRole[] @default([CUSTOMER])
  status              UserStatus @default(INACTIVE)
  activation_code     String?
  activationExpiresAt DateTime?
  fullName            String?
  phone               String?
  avatar              String?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  Store       Store?
  UserAddress UserAddress[]
  Review      Review[]
  Cart        Cart[]
  Order       Order[]
  Wishlist    Wishlist[]

  //mapping
  @@map("users")
}

model UserAddress {
  // ! TODO need add some information
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  label         AddressLabel @default(HOME)
  address       String
  city          String?
  province      String?
  postalCode    String?
  receiverName  String
  receiverPhone String
  isPrimary     Boolean      @default(false)

  userId String  @db.ObjectId
  user   User    @relation(fields: [userId], references: [id])
  Order  Order[]

  @@map("user_addresses")
}

model Store {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String      @unique
  domain      String?
  description String?
  logo        String?
  status      StoreStatus @default(ACTIVE)

  adminId String @unique @db.ObjectId
  admin   User   @relation(fields: [adminId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Product   Product[]

  @@map("stores")
}

// ============ BRAND & CATEGORY =====================

model Brand {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Product   Product[]

  @@map("brands")
}

model Category {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  name            String            @unique
  slug            String            @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ProductCategory ProductCategory[]

  @@map("categories")
}

// ===================== PRODUCT ============

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

// Junction table for Product-Category many-to-many relationship
model ProductCategory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  categoryId String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@map("product_categories")
}

model Product {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  storeId String @db.ObjectId
  store   Store  @relation(fields: [storeId], references: [id])

  name            String
  slug            String            @unique
  description     String?
  price           Float
  status          ProductStatus     @default(ACTIVE)
  images          String[]
  ProductCategory ProductCategory[]
  brandId         String            @db.ObjectId
  brand           Brand             @relation(fields: [brandId], references: [id])

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  Review    Review[]
  CartItem  CartItem[]
  OrderItem OrderItem[]
  Wishlist  Wishlist[]
}

// ========== REVIEWS & RATINGS ==========
model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  userId     String   @db.ObjectId
  rating     Int // Rating from 1 to 5
  title      String?
  comment    String?
  isVerified Boolean  @default(false) // Whether the purchase was verified
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // User can only review a product once
  @@map("reviews")
}

// ========== SHOPPING CART ==========
model Cart {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId           String   @db.ObjectId
  productVariantId String   @db.ObjectId
  quantity         Int      @default(1)
  price            Float // Price at time of adding to cart
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product   Product? @relation(fields: [productId], references: [id])
  productId String?  @db.ObjectId

  @@unique([cartId, productVariantId]) // Prevent duplicate variants in cart
  @@map("cart_items")
}

// ========== ORDER MANAGEMENT ==========
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Order {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String      @unique // Generated unique order number
  userId            String      @db.ObjectId
  shippingAddressId String      @db.ObjectId
  status            OrderStatus @default(PENDING)
  subtotal          Float // Total before discounts and tax
  shippingCost      Float       @default(0)
  tax               Float       @default(0)
  discount          Float       @default(0) // Total discount from vouchers
  total             Float // Final total amount
  notes             String?
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user            User           @relation(fields: [userId], references: [id])
  shippingAddress UserAddress    @relation(fields: [shippingAddressId], references: [id])
  orderItems      OrderItem[]
  payment         Payment?
  usedVouchers    OrderVoucher[]

  @@map("orders")
}

model OrderItem {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String   @db.ObjectId
  productId        String   @db.ObjectId
  productVariantId String?  @db.ObjectId
  quantity         Int
  price            Float // Price at the time of purchase
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ========== PAYMENT ==========
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  E_WALLET
  COD
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String        @unique @db.ObjectId
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique // External payment gateway transaction ID
  gatewayData   Json? // Store additional payment gateway response data
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ========== VOUCHERS ==========
enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  USED_UP
}

model ProductVoucher {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  code           String        @unique
  name           String
  description    String?
  type           VoucherType
  value          Float // Percentage or fixed amount
  minPurchase    Float? // Minimum purchase amount to use voucher
  maxDiscount    Float? // Maximum discount for percentage type
  usageLimit     Int? // Total usage limit
  usageCount     Int           @default(0)
  userUsageLimit Int? // Per user usage limit
  status         VoucherStatus @default(ACTIVE)
  validFrom      DateTime
  validUntil     DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  orderVouchers OrderVoucher[]

  @@map("product_vouchers")
}

model DeliveryVoucher {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  code           String        @unique
  name           String
  description    String?
  type           VoucherType
  value          Float // Percentage or fixed amount
  minPurchase    Float? // Minimum purchase amount to use voucher
  maxDiscount    Float? // Maximum discount for percentage type
  usageLimit     Int? // Total usage limit
  usageCount     Int           @default(0)
  userUsageLimit Int? // Per user usage limit
  status         VoucherStatus @default(ACTIVE)
  validFrom      DateTime
  validUntil     DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  orderVouchers OrderVoucher[]

  @@map("delivery_vouchers")
}

// Junction table for vouchers used in orders
model OrderVoucher {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String   @db.ObjectId
  productVoucherId  String?  @db.ObjectId
  deliveryVoucherId String?  @db.ObjectId
  discountAmount    Float // Actual discount applied
  createdAt         DateTime @default(now())

  // Relations
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVoucher  ProductVoucher?  @relation(fields: [productVoucherId], references: [id])
  deliveryVoucher DeliveryVoucher? @relation(fields: [deliveryVoucherId], references: [id])

  @@map("order_vouchers")
}

// ========== WISHLIST ==========
model Wishlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // User can only have a product in wishlist once
  @@map("wishlists")
}
